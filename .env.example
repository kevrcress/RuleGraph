# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rulegraph

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM ───────────────────────────────────────────────────────────────────────
# Optional at startup — can be set via Admin → Settings in the UI instead.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: route extractor through a LiteLLM proxy (e.g. Ollama) instead of Anthropic.
# When set, ANTHROPIC_API_KEY is not required for extraction.
# Setup: pip install litellm && litellm --model ollama/gemma3 --port 4000
# LITELLM_BASE_URL=http://localhost:4000

# ── Ingest tuning (background worker) ───────────────────────────────────────────
# These are read from the environment by app/config.py — the matching keys under
# `worker:` in rulegraph.yaml are documentation only and are NOT loaded at runtime.
# Defaults shown; uncomment to override.
# LLM_REQUEST_TIMEOUT_SECONDS=300      # per-file LLM call timeout
# INGEST_JOB_TIMEOUT_SECONDS=7200      # arq hard kill ceiling for one ingest job (2h)
# INGEST_STALE_GRACE_SECONDS=600       # extra slack past the job timeout before a run is "stale"
# INGEST_BATCH_POLL_RESERVE_SECONDS=900  # buffer kept below the job timeout for clone+scoring+results;
#                                        # Batch poll budget = JOB_TIMEOUT − this. See DEC-045.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
RULEGRAPH_ENCRYPTION_KEY=

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Shared secret for HMAC validation of incoming ADO webhooks.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_TEST_SECRET=
